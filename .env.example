# Database Configuration (Commented out - using SQLite)
# For Docker: use 'db' as host, for local development: use 'localhost'
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=tripmate_db
# DB_USER=tripmate
# DB_PASSWORD=tripmate_password

# Application Configuration
APPLICATION_NAME=TripMatee
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=False

# Frontend URL
FRONTEND_URL_RESET=http://localhost:5173

# Email Configuration (Gmail example)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id

# Redis Configuration
# For Docker: use 'redis' as host, for local development: use 'localhost'
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# For Gmail, you need to:
# 1. Enable 2-factor authentication on your Google account
# 2. Generate an "App Password" specifically for this application
# 3. Use that app password as MAIL_PASSWORD
